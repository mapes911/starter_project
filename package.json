{
  "name": "starter-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
